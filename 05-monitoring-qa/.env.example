TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# --- OpenRouter (разработка) ---
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key
LLM_BASE_URL=https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://openrouter.ai/api/v1
MODEL_TEXT=openai/gpt-4o-mini
MODEL_IMAGE=openai/gpt-4o-mini
MODEL_AUDIO=openai/whisper-1

# --- Ollama (локально, медданные) ---
# LLM_PROVIDER=ollama
# OPENROUTER_API_KEY=
# LLM_BASE_URL=http://localhost:11434/v1
# MODEL_TEXT=llama3.2
# MODEL_IMAGE=llava
# MODEL_AUDIO=whisper

# --- Vision через OpenRouter (гибрид: текст локально, фото в облаке) ---
# IMAGE_LLM_BASE_URL=https://openrouter.ai/api/v1
# IMAGE_OPENROUTER_API_KEY=your_openrouter_api_key
# MODEL_IMAGE=google/gemini-2.5-flash

# --- Audio через OpenRouter (гибрид) ---
# AUDIO_LLM_BASE_URL=https://openrouter.ai/api/v1
# AUDIO_OPENROUTER_API_KEY=your_openrouter_api_key
# MODEL_AUDIO=openai/whisper-1

DATA_FILE=data/meals.json
CARB_RATIO=12
INSULIN_SENSITIVITY=2.0
TARGET_GLUCOSE_MIN=5.0
TARGET_GLUCOSE_MAX=10.0
FPU_RATIO=10
# SYSTEM_PROMPT=опционально; дефолт — в src/nika/config.py

# --- RAG (LangChain + OpenRouter) ---
MODEL_EMBEDDING=openai/text-embedding-3-small
# EMBEDDING_PROVIDER=openrouter
# OLLAMA_EMBEDDING_BASE_URL=http://localhost:11434
# MODEL_RAG=google/gemini-2.5-flash
RETRIEVER_K=4
DATA_PDF=data/rukovodstvo_dlya_detei_i_ih_roditelei_saharnii_diabet_1_tipa_chto_neobhodimo_znat_178.pdf

# --- Чанкинг PDF ---
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# CHUNK_SEPARATORS=default

# --- Отображение источников ---
SHOW_SOURCES=false

# --- LangSmith (трейсинг и evaluation) ---
LANGSMITH_API_KEY=
LANGSMITH_TRACING_V2=true
LANGSMITH_PROJECT=05-rag-assistant
LANGSMITH_DATASET=05-rag-qa-dataset

# --- RAGAS (оценка качества) ---
RAGAS_LLM_MODEL=openai/gpt-oss-20b:free
RAGAS_EMBEDDING_MODEL=openai/text-embedding-3-large
