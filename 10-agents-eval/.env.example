TELEGRAM_BOT_TOKEN=

# openrouter | ollama
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://openrouter.ai/api/v1
MODEL_TEXT=openai/gpt-4o-mini
MODEL_IMAGE=openai/gpt-4o-mini
MODEL_AUDIO=openai/whisper-1

SHOW_SOURCES=false

# RAG
EMBEDDING_PROVIDER=openai
MODEL_EMBEDDING=openai/text-embedding-3-small
RAG_RETRIEVAL_MODE=semantic
DATA_PDF=data/rukovodstvo_dlya_detei_i_ih_roditelei_saharnii_diabet_1_tipa_chto_neobhodimo_znat_178.pdf

# Agent middleware
# Для e2e с несколькими tool-ходами лучше >=5
AGENT_RUN_LIMIT=3

# MCP
MCP_SERVER_URL=http://localhost:8000/mcp

# LangSmith
LANGSMITH_API_KEY=
LANGSMITH_TRACING_V2=false
LANGSMITH_PROJECT=10-agents-eval
LANGSMITH_DATASET=05-rag-qa-dataset

# RAGAS
RAGAS_LLM_MODEL=openai/gpt-4o-mini
RAGAS_EMBEDDING_MODEL=openai/text-embedding-3-large
RAGAS_EMBEDDING_PROVIDER=openai

# AgentEvals (LLM-as-a-Judge). Формат: provider:model. Нужен structured output.
AGENTEVALS_LLM_MODEL=openai:gpt-4o
